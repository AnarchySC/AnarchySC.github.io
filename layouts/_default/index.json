{{- $pages := where .Site.RegularPages "Section" "blog" -}}
[
{{- range $i, $p := $pages }}
{{- if $i }},{{ end }}
{
  "title": {{ $p.Title | jsonify }},
  "url": {{ $p.RelPermalink | jsonify }},
  "date": {{ $p.Date.Format "2006-01-02" | jsonify }},
  "tags": {{ $p.Params.tags | jsonify }},
  "summary": {{ $p.Summary | plainify | truncate 200 | jsonify }}
}
{{- end }}
]
